<Window x:Class="mmmmmmmm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf" 
        Title="Вычислитель MVVM" Height="500" Width="900">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="Undo" Width="80" Height="25" Margin="0,0,10,0" Click="UndoButton_OnClick"/>
                <Button Content="Redo" Width="80" Height="25" Click="Redo_OnClick"/>
            </StackPanel>

            <TextBlock Text="Путь к файлу данных:" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding InputViewModel.FilePath, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                <Button Content="..." Grid.Column="1" Width="30" Click="SelectFile_OnClick"/>
            </Grid>
            <Button Content="Загрузить и рассчитать" Height="35" Margin="0,0,0,20" Click="LoadData_OnClick"/>

            <TextBlock Text="Входные данные:" FontWeight="Bold" Margin="0,0,0,5"/>

            <TextBox Text="{Binding InputViewModel.CurrentImportedData}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Height="250" VerticalScrollBarVisibility="Auto" Background="#FFF5F5F5"/>
        </StackPanel>

        <oxy:PlotView Model="{Binding SolverViewModel.PlotModel}" Grid.Column="1"/>
    </Grid>
</Window>